# Copy this file to .env and fill in your values

# --- LLM Provider ---
# "groq"        → free, fast (recommended) — get key at console.groq.com
# "openai"      → best quality — get key at platform.openai.com
# "huggingface" → fully local, no API key, slower
LLM_PROVIDER=groq

# --- Groq Settings (required if LLM_PROVIDER=groq) ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
# Other free Groq models: llama-3.3-70b-versatile, gemma2-9b-it, mixtral-8x7b-32768

# --- OpenAI Settings (required if LLM_PROVIDER=openai) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-3.5-turbo
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Vector DB Backend ---
# "chroma" (default, persistent, no extra setup)
# "faiss"  (fast in-process, saved to FAISS_INDEX_PATH)
VECTOR_DB=chroma
FAISS_INDEX_PATH=./faiss_index

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval ---
TOP_K=5

# --- LLM generation ---
LLM_TEMPERATURE=0.1
MAX_TOKENS=1024

# --- UI / uploads ---
SNIPPET_MAX_CHARS=200
MAX_UPLOAD_SIZE_MB=20

# --- Paths ---
DOCUMENTS_DIR=./data/documents
CHROMA_PERSIST_DIR=./chroma_db

# --- Google Drive ingestion (bonus feature) ---
# See src/ingestion/gdrive_loader.py for full setup instructions.
# GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json
